# 서버 포트
PORT=4000

# ---------------------------------------------------------------------------
# 1) 행정안전부 도로명주소 API (주소 검색/정제용)
#    신청: https://www.juso.go.kr/addrlink/openApi/apiEasyGuide.do
#    -> "오픈API 신청" 후 발급받은 승인키(confmKey)를 입력
# ---------------------------------------------------------------------------
JUSO_API_KEY=

# ---------------------------------------------------------------------------
# 2) 공공데이터포털 - 국토교통부 건축물대장정보 서비스 (건물유형/사용승인일)
#    신청: https://www.data.go.kr/data/15057200/openapi.do
#    (검색창에 "건축물대장정보 서비스" 검색 -> 활용신청 -> 일반 인증키(Decoding) 사용)
#    아래 이름 중 아무거나 하나만 채우면 인식됩니다 (여러 개 채워도 무방, 위에서부터 우선순위).
# ---------------------------------------------------------------------------
BUILDING_REGISTER_API_KEY=
PUBLIC_DATA_API_KEY=
DATA_GO_KR_API_KEY=

# ---------------------------------------------------------------------------
# 3) 네이버 검색 오픈API (뉴스/블로그 - 재건축/재개발 관련 정보)
#    신청: https://developers.naver.com/apps/#/register
#    -> "검색" API 선택 후 발급받은 Client ID / Client Secret 입력
# ---------------------------------------------------------------------------
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# 4) (선택, 서울만 지원) 공공데이터포털 - 서울특별시_서울시 정비사업 데이터
#    신청: https://www.data.go.kr/data/15097425/fileData.do -> 활용신청
#    승인 후 "마이페이지 > 개발계정 상세보기"에 나오는 정확한 Request URL을
#    SEOUL_REDEVELOPMENT_API_URL 에 붙여넣어 주세요 (기본값은 추정값이라 다를 수 있음).
#    ⚠️ 조합설립인가일/사업시행인가일/관리처분계획인가일이 각각 나오지 않고
#    "현재 단계"+"그 단계의 고시일" 1건만 제공됩니다. 미채우면 이 기능만 비활성화됩니다.
# ---------------------------------------------------------------------------
SEOUL_REDEVELOPMENT_API_KEY=
SEOUL_REDEVELOPMENT_API_URL=

# ---------------------------------------------------------------------------
# 5) (선택, 부산만 지원) 공공데이터포털 - 부산광역시_정비사업 정보
#    신청: https://www.data.go.kr/data/3069406/openapi.do -> 활용신청
#    ⚠️ 조합설립인가일/사업시행인가일/관리처분계획인가일 없음 - "사업추진단계" 텍스트만.
#    ⚠️ 주소 조회 파라미터가 없어 전체 목록에서 위치 텍스트로 매칭 (서울보다 정확도 낮음).
#    미채우면 이 기능만 비활성화되고 나머지는 그대로 동작합니다.
# ---------------------------------------------------------------------------
BUSAN_REDEVELOPMENT_API_KEY=

# ---------------------------------------------------------------------------
# 전국 커버리지 관련 안내
# 전국 통합 "재건축·재개발 정비구역 정보 API"는 존재하지 않습니다 (확인 완료).
# 지자체마다 다른 포털/다른 구조로 각자 등록되어 있어, 서울/부산처럼 지역별로
# 하나씩 확인 후 server/services/regionalRedevelopmentService.js 에 추가해야 합니다.
# 다른 지역이 필요하면 어느 지역이 우선인지 알려주세요.
# ---------------------------------------------------------------------------
